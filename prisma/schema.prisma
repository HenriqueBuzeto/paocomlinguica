// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  ADMIN
  GERENTE
  OPERADOR
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum MovementStatus {
  ACTIVE
  CANCELED
}

enum CashMovementType {
  VENDA
  SANGRIA
  SUPRIMENTO
  DESPESA
  ENTRADA_MANUAL
  SAIDA_MANUAL
  CANCELAMENTO
}

enum SaleStatus {
  COMPLETED
  CANCELED
}

enum PaymentMethodKind {
  CASH
  PIX
  CARD
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])

  cashRegistersOpened CashRegister[] @relation("cash_register_opened_by")
  cashRegistersClosed CashRegister[] @relation("cash_register_closed_by")
  movements           CashMovement[]
  salesOperated       Sale[] @relation("sale_operator")
  salesCanceled       Sale[] @relation("sale_canceled_by")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
}

model Role {
  id   String   @id @default(cuid())
  name RoleName @unique
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CashRegister {
  id             String             @id @default(cuid())
  status         CashRegisterStatus @default(OPEN)

  openedAt       DateTime @default(now())
  openingBalance Decimal  @db.Decimal(12, 2)

  closedAt               DateTime?
  closingBalanceReported Decimal? @db.Decimal(12, 2)
  expectedBalance        Decimal? @db.Decimal(12, 2)
  difference             Decimal? @db.Decimal(12, 2)

  openedById String
  openedBy   User   @relation("cash_register_opened_by", fields: [openedById], references: [id])

  closedById String?
  closedBy   User?  @relation("cash_register_closed_by", fields: [closedById], references: [id])

  movements CashMovement[]
  sales     Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([openedById, status])
  @@index([openedAt])
}

model CashMovement {
  id String @id @default(cuid())

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  type   CashMovementType
  status MovementStatus @default(ACTIVE)

  amount      Decimal @db.Decimal(12, 2)
  description String?

  saleId String?
  sale   Sale? @relation(fields: [saleId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  canceledAt DateTime?

  @@index([cashRegisterId, createdAt])
  @@index([type, status])
  @@index([userId, createdAt])
  @@index([saleId])
}

model Category {
  id     String @id @default(cuid())
  name   String @unique
  active Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id         String  @id @default(cuid())
  name       String
  price      Decimal @db.Decimal(12, 2)
  cost       Decimal? @db.Decimal(12, 2)
  active     Boolean @default(true)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  saleItems SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([categoryId])
}

model Sale {
  id String @id @default(cuid())

  status SaleStatus @default(COMPLETED)

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  operatorId String
  operator   User   @relation("sale_operator", fields: [operatorId], references: [id])

  customerName String?
  discount     Decimal @default(0) @db.Decimal(12, 2)
  deliveryFee  Decimal @default(0) @db.Decimal(12, 2)
  notes        String?

  cashReceived Decimal? @db.Decimal(12, 2)
  changeDue    Decimal? @db.Decimal(12, 2)

  total Decimal @db.Decimal(12, 2)

  items     SaleItem[]
  payments  SalePayment[]
  movements CashMovement[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  canceledAt DateTime?

  canceledById     String?
  canceledBy       User?   @relation("sale_canceled_by", fields: [canceledById], references: [id])
  canceledReason   String?

  @@index([cashRegisterId, createdAt])
  @@index([operatorId, createdAt])
  @@index([status, createdAt])
}

model SaleItem {
  id String @id @default(cuid())

  saleId    String
  sale      Sale   @relation(fields: [saleId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
}

model PaymentMethod {
  id     String @id @default(cuid())
  name   String @unique
  kind   PaymentMethodKind @default(CASH)
  active Boolean @default(true)

  salePayments SalePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalePayment {
  id String @id @default(cuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([paymentMethodId])
}
